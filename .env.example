# OpenRouter API Key - get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Site URL - used for OpenRouter HTTP-Referer header
NEXT_PUBLIC_SITE_URL=https://your-app.up.railway.app

# Railway PostgreSQL - set automatically when you add a Postgres service in Railway
# Format: postgresql://postgres:<password>@<host>:<port>/railway
DATABASE_URL=postgresql://postgres:password@host:5432/railway
